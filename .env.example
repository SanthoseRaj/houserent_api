NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/house_rent_app
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
APP_BASE_URL=http://localhost:5000
CLIENT_BASE_URL=http://localhost:3000

# Uploads
STORAGE_DRIVER=auto
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@houserent.local
OTP_EXPIRY_MINUTES=10
ENABLE_DEV_OTP_RESPONSE=true
ENABLE_DEV_DEMO_ACCOUNTS=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=inr
